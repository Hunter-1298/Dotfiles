#!/usr/bin/env bash
# pi-worktree-gc: garbage-collect agent/* worktrees and branches left behind
# by the auto-worktree extension.
#
# Usage:
#   pi-worktree-gc                # dry-run, scans $PI_PROJECTS_ROOT (default ~/Projects)
#   pi-worktree-gc /path/to/repo  # dry-run, scans a single repo or directory of repos
#   pi-worktree-gc --apply        # actually delete the safe ones
#
# Policy (matches auto-worktree.ts safeCleanup):
#   1. If the worktree still has a directory, working tree must be clean.
#   2. The agent branch must have zero commits past its base branch AND no
#      remote counterpart at origin/<branch>. A remote means the branch may
#      be the source of an open PR — deleting it would close the PR — so we
#      always leave such branches alone.
#   3. When safe: remove the worktree entry/dir, delete the local branch,
#      drop the piBase config. Remote branches are never deleted.
#
# Anything that fails a check is reported and left in place.

set -uo pipefail

apply=0
roots=()
for arg in "$@"; do
  case "$arg" in
    --apply) apply=1 ;;
    -h|--help) sed -n '2,18p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    -*) echo "pi-worktree-gc: unknown flag $arg" >&2; exit 2 ;;
    *) roots+=("$arg") ;;
  esac
done
if [[ ${#roots[@]} -eq 0 ]]; then
  roots=("${PI_PROJECTS_ROOT:-$HOME/Projects}")
fi

mode_label="DRY-RUN"; [[ $apply -eq 1 ]] && mode_label="APPLY"
echo "pi-worktree-gc [$mode_label] roots: ${roots[*]}"

# Track per-run stats.
total_safe=0
total_skip=0
total_err=0

# Resolve a "main repo" toplevel from a candidate path: if .git is a file
# (linked worktree) follow common-dir, else use rev-parse --show-toplevel.
resolve_main_repo() {
  local path="$1"
  if ! git -C "$path" rev-parse --git-dir >/dev/null 2>&1; then
    return 1
  fi
  local common
  common="$(git -C "$path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || return 1
  # common-dir is .../foo/.git for a main repo, or .../foo/.git for a linked
  # worktree too (since common-dir resolves to the main repo's git dir).
  dirname "$common"
}

base_key() { echo "branch.$1.piBase"; }

# Returns 0 (safe) or non-zero with a stderr reason.
branch_is_safe() {
  local repo="$1" branch="$2" base="$3"
  # Refuse to touch any branch that still has a remote counterpart — it may
  # be the source of an open PR.
  if git -C "$repo" rev-parse --verify --quiet "refs/remotes/origin/$branch" >/dev/null; then
    echo "remote branch origin/$branch exists (likely PR source)" >&2
    return 1
  fi
  local ahead
  ahead="$(git -C "$repo" rev-list --count "$base..$branch" 2>/dev/null)" || {
    echo "rev-list $base..$branch failed" >&2; return 1; }
  if [[ "$ahead" == "0" ]]; then return 0; fi
  echo "$ahead unpushed commit(s)" >&2
  return 1
}

# Working tree dirty?
worktree_is_dirty() {
  local dir="$1"
  [[ -d "$dir" ]] || return 1
  local s
  s="$(git -C "$dir" status --porcelain 2>/dev/null)"
  [[ -n "$s" ]]
}

# Apply the cleanup steps (worktree remove -> branch -D -> config unset).
# $1 is the main repo to drive git from, $2 the worktree dir (may be empty
# / missing), $3 the branch. Remote branches are never deleted; branch_is_safe
# already refuses anything that still has a remote counterpart.
do_cleanup() {
  local repo="$1" wt="$2" branch="$3"
  if [[ -n "$wt" && -d "$wt" ]]; then
    if ! git -C "$repo" worktree remove "$wt" 2>&1 | sed 's/^/    wt:   /'; then
      echo "    ! worktree remove failed; aborting"
      return 1
    fi
  else
    # Directory already gone — just prune the metadata.
    git -C "$repo" worktree prune >/dev/null 2>&1 || true
  fi
  if ! git -C "$repo" branch -D "$branch" 2>&1 | sed 's/^/    br:   /'; then
    echo "    ! branch delete failed"
    return 1
  fi
  git -C "$repo" config --unset "$(base_key "$branch")" 2>/dev/null || true
  return 0
}

# Collect every (worktree_dir, branch) pair plus loose agent/* branches that
# have no worktree entry. We emit lines of form:
#   <kind> <branch> <worktree-dir-or-empty>
# kinds: live (dir exists), prunable (dir gone but worktree entry present),
# loose (no worktree entry).
list_agent_entries() {
  local repo="$1"
  # worktree entries
  git -C "$repo" worktree list --porcelain 2>/dev/null | awk '
    BEGIN { wt=""; br=""; prunable=0 }
    /^worktree / { if (wt != "" && br ~ /^agent\//) { print (prunable ? "prunable" : "live"), br, wt }
                   wt=$2; br=""; prunable=0 }
    /^branch refs\/heads\// { sub("^branch refs/heads/", "", $0); br=$0 }
    /^prunable/ { prunable=1 }
    END { if (wt != "" && br ~ /^agent\//) { print (prunable ? "prunable" : "live"), br, wt } }
  '
  # loose branches (in branch list but never matched a worktree entry)
  local wt_branches
  wt_branches="$(git -C "$repo" worktree list --porcelain 2>/dev/null | awk '/^branch refs\/heads\/agent\//{sub("^branch refs/heads/","",$0); print $0}')"
  git -C "$repo" for-each-ref --format='%(refname:short)' refs/heads/agent/ 2>/dev/null \
    | while read -r b; do
        if ! grep -Fxq -- "$b" <<<"$wt_branches"; then
          echo "loose $b "
        fi
      done
}

# Iterate one repo (its main toplevel).
process_repo() {
  local repo="$1"
  local entries
  entries="$(list_agent_entries "$repo")" || return 0
  [[ -z "$entries" ]] && return 0

  echo
  echo "repo: $repo"
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local kind branch wt
    kind="$(awk '{print $1}' <<<"$line")"
    branch="$(awk '{print $2}' <<<"$line")"
    wt="$(awk '{for (i=3;i<=NF;++i) printf "%s%s", $i, (i<NF?" ":"")}' <<<"$line")"

    # Recover base from config; fall back to main / master.
    local base
    base="$(git -C "$repo" config --get "$(base_key "$branch")" 2>/dev/null || true)"
    if [[ -z "$base" ]]; then
      for cand in main master; do
        if git -C "$repo" rev-parse --verify --quiet "refs/heads/$cand" >/dev/null; then
          base="$cand"; break
        fi
      done
    fi
    if [[ -z "$base" ]]; then
      printf "  [%-8s] %s\n    SKIP: no base branch (no piBase config and no main/master)\n" "$kind" "$branch"
      total_skip=$((total_skip+1))
      continue
    fi

    # Dirty check only meaningful for live worktrees.
    if [[ "$kind" == "live" ]] && worktree_is_dirty "$wt"; then
      printf "  [%-8s] %s (base %s)\n    SKIP: uncommitted or untracked changes in %s\n" "$kind" "$branch" "$base" "$wt"
      total_skip=$((total_skip+1))
      continue
    fi

    local reason
    if ! reason="$(branch_is_safe "$repo" "$branch" "$base" 2>&1 >/dev/null)"; then
      printf "  [%-8s] %s (base %s)\n    SKIP: %s\n" "$kind" "$branch" "$base" "$reason"
      total_skip=$((total_skip+1))
      continue
    fi

    printf "  [%-8s] %s (base %s)\n    SAFE: would delete" "$kind" "$branch" "$base"
    [[ -n "$wt" ]] && printf " worktree %s," "$wt"
    printf " local branch\n"
    total_safe=$((total_safe+1))

    if [[ $apply -eq 1 ]]; then
      if do_cleanup "$repo" "$wt" "$branch"; then
        echo "    DONE"
      else
        total_safe=$((total_safe-1))
        total_err=$((total_err+1))
      fi
    fi
  done <<<"$entries"
}

# Build the list of main repos under each root.
declare -A seen_repos=()
for root in "${roots[@]}"; do
  if [[ ! -e "$root" ]]; then
    echo "pi-worktree-gc: root not found: $root" >&2
    continue
  fi
  if main="$(resolve_main_repo "$root" 2>/dev/null)" && [[ -n "$main" ]]; then
    seen_repos["$main"]=1
  else
    # Treat as a directory of repos.
    while IFS= read -r -d '' candidate; do
      if main="$(resolve_main_repo "$candidate" 2>/dev/null)" && [[ -n "$main" ]]; then
        seen_repos["$main"]=1
      fi
    done < <(find "$root" -mindepth 1 -maxdepth 2 -type d -name ".git" -print0 2>/dev/null)
  fi
done

for repo in "${!seen_repos[@]}"; do
  process_repo "$repo"
done

echo
echo "summary: safe=$total_safe skipped=$total_skip errors=$total_err mode=$mode_label"
if [[ $apply -eq 0 && $total_safe -gt 0 ]]; then
  echo "        re-run with --apply to actually delete the SAFE entries."
fi
